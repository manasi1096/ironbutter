# Zerodha Kite Connect Credentials
# =================================
# Get API key/secret from: https://developers.kite.trade/
KITE_API_KEY=your_api_key_here
KITE_API_SECRET=your_api_secret_here
KITE_ACCESS_TOKEN=

# Zerodha Login Credentials (for auto-login)
# ==========================================
KITE_USER_ID=your_zerodha_user_id
KITE_PASSWORD=your_zerodha_password
TOTP_SECRET=your_totp_secret_from_authenticator_app

# Telegram Notifications (Optional)
# =================================
# Create bot via @BotFather, get chat ID via @userinfobot
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Trading Parameters
# ==================
TRADING_SYMBOL=NIFTY
QUANTITY=65
HEDGE_DISTANCE=150
STOP_LOSS_PERCENT=50
GAP_THRESHOLD=50
EXIT_TIME=15:15

# OpenAlgo (Optional)
# ===================
OPENALGO_API_KEY=
HOST_URL=http://localhost:5000
